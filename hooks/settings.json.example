{
  "_comment": "Wire the 3 hooks into ~/.claude/settings.json. Merge into your existing hooks block; do NOT overwrite the whole file. Absolute paths recommended so hooks fire regardless of cwd. On Windows, use the same forward-slash form or escape backslashes.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/YOUR_USERNAME/.claude/hooks/pretool-destructive-guard.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell|Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/YOUR_USERNAME/.claude/hooks/posttool-fabrication-guard.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/YOUR_USERNAME/.claude/hooks/stop-claim-audit.py\""
          }
        ]
      }
    ]
  }
}
